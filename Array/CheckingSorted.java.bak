import java.util.Scanner;
class  CheckingSorted
{
	public static void main(String[] args) 
	{
		System.out.println("Checking the given array is sorted or not ");
		Scanner sc =new Scanner(System.in);
		System.out.println("Enter the size of array ");
		int n=sc.nextInt();
		int []arr=new int[n];
		System.out.println("Enter all element of array ");
		for(int i=0;i<n;i++){
			arr[i]=sc.nextInt();
		}
		System.out.println("Checking here array is sorted or not");
		for(int i=1;i<n;i++){
			if(arr[i]>arr[i-1]){
				System.out.println("It is an unsorted array ");
			}
			else{
				System.out.println("Yes it is sorted array");
			}
		}
		
	}
}
